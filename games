<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>最简俄罗斯方块</title>
    <style>
        body {
            background: #202028;
            color: #fff;
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }
        #score {
            font-size: 24px;
            margin-bottom: 10px;
        }
        canvas {
            border: 2px solid #fff;
            background-color: #111;
        }
        .help {
            margin-top: 15px;
            color: #aaa;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div id="score">得分: 0</div>
    <canvas id="tetris" width="240" height="400"></canvas>
    <div class="help">操作：← → 左右移动 | ↑ 旋转 | ↓ 加速下落</div>

<script>
const canvas = document.getElementById('tetris');
const context = canvas.getContext('2d');

// 放大画面，每个格子 20x20 像素
context.scale(20, 20);

// 1. 创建游戏地图 (12列 x 20行)
const arena = createMatrix(12, 20);

// 2. 定义方块形状 (I, J, L, O, S, T, Z)
const pieces = 'ILJOTSZ';
const colors = [
    null, '#FF0D72', '#0DC2FF', '#0DFF72', 
    '#F538FF', '#FF8E0D', '#FFE138', '#3877FF'
];

// 玩家状态
const player = {
    pos: {x: 0, y: 0},
    matrix: null,
    score: 0,
};

// 核心逻辑：创建矩阵
function createMatrix(w, h) {
    const matrix = [];
    while (h--) { matrix.push(new Array(w).fill(0)); }
    return matrix;
}

// 创建方块形状
function createPiece(type) {
    if (type === 'T') return [[0,0,0],[1,1,1],[0,1,0]];
    if (type === 'O') return [[2,2],[2,2]];
    if (type === 'L') return [[0,3,0],[0,3,0],[0,3,3]];
    if (type === 'J') return [[0,4,0],[0,4,0],[4,4,0]];
    if (type === 'I') return [[0,5,0,0],[0,5,0,0],[0,5,0,0],[0,5,0,0]];
    if (type === 'S') return [[0,6,6],[6,6,0],[0,0,0]];
    if (type === 'Z') return [[7,7,0],[0,7,7],[0,0,0]];
}

// 绘制单矩阵（地图或方块）
function drawMatrix(matrix, offset) {
    matrix.forEach((row, y) => {
        row.forEach((value, x) => {
            if (value !== 0) {
                context.fillStyle = colors[value];
                context.fillRect(x + offset.x, y + offset.y, 1, 1);
            }
        });
    });
}

// 渲染整个画面
function draw() {
    context.fillStyle = '#000';
    context.fillRect(0, 0, canvas.width, canvas.height);

    drawMatrix(arena, {x: 0, y: 0}); // 画固定好的方块
    drawMatrix(player.matrix, player.pos); // 画当前下落的方块
}

// 合并方块到地图
function merge(arena, player) {
    player.matrix.forEach((row, y) => {
        row.forEach((value, x) => {
            if (value !== 0) {
                arena[y + player.pos.y][x + player.pos.x] = value;
            }
        });
    });
}

// 碰撞检测
function collide(arena, player) {
    const [m, o] = [player.matrix, player.pos];
    for (let y = 0; y < m.length; ++y) {
        for (let x = 0; x < m[y].length; ++x) {
            if (m[y][x] !== 0 &&
               (arena[y + o.y] && arena[y + o.y][x + o.x]) !== 0) {
                return true;
            }
        }
    }
    return false;
}

// 消除满行
function arenaSweep() {
    let rowCount = 1;
    outer: for (let y = arena.length - 1; y > 0; --y) {
        for (let x = 0; x < arena[y].length; ++x) {
            if (arena[y][x] === 0) {
                continue outer;
            }
        }
        const row = arena.splice(y, 1)[0].fill(0);
        arena.unshift(row);
        ++y;

        player.score += rowCount * 10;
        rowCount *= 2;
    }
    document.getElementById('score').innerText = "得分: " + player.score;
}

// 旋转矩阵
function rotate(matrix, dir) {
    for (let y = 0; y < matrix.length; ++y) {
        for (let x = 0; x < y; ++x) {
            [matrix[x][y], matrix[y][x]] = [matrix[y][x], matrix[x][y]];
        }
    }
    if (dir > 0) { matrix.forEach(row => row.reverse()); } 
    else { matrix.reverse(); }
}

// 玩家移动逻辑
function playerMove(dir) {
    player.pos.x += dir;
    if (collide(arena, player)) {
        player.pos.x -= dir;
    }
}

// 玩家旋转逻辑
function playerRotate(dir) {
    const pos = player.pos.x;
    let offset = 1;
    rotate(player.matrix, dir);
    while (collide(arena, player)) {
        player.pos.x += offset;
        offset = -(offset + (offset > 0 ? 1 : -1));
        if (offset > player.matrix[0].length) {
            rotate(player.matrix, -dir);
            player.pos.x = pos;
            return;
        }
    }
}

// 方块下落
function playerDrop() {
    player.pos.y++;
    if (collide(arena, player)) {
        player.pos.y--;
        merge(arena, player);
        playerReset();
        arenaSweep();
    }
    dropCounter = 0;
}

// 重置新方块
function playerReset() {
    player.matrix = createPiece(pieces[pieces.length * Math.random() | 0]);
    player.pos.y = 0;
    player.pos.x = (arena[0].length / 2 | 0) - (player.matrix[0].length / 2 | 0);
    
    // 如果刚生成就碰撞，游戏结束
    if (collide(arena, player)) {
        arena.forEach(row => row.fill(0));
        player.score = 0;
        document.getElementById('score').innerText = "得分: 0";
    }
}

// 游戏主循环计时
let dropCounter = 0;
let dropInterval = 1000; // 每 1000 毫秒（1秒）下落一格
let lastTime = 0;

function update(time = 0) {
    const deltaTime = time - lastTime;
    lastTime = time;

    dropCounter += deltaTime;
    if (dropCounter > dropInterval) {
        playerDrop();
    }

    draw();
    requestAnimationFrame(update);
}

// 监听键盘事件
document.addEventListener('keydown', event => {
    if (event.keyCode === 37) {        // 左箭头
        playerMove(-1);
    } else if (event.keyCode === 39) { // 右箭头
        playerMove(1);
    } else if (event.keyCode === 40) { // 下箭头
        playerDrop();
    } else if (event.keyCode === 38) { // 上箭头
        playerRotate(1);
    }
});

// 初始化游戏
playerReset();
update();
</script>
</body>
</html>
